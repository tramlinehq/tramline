<div class="flex flex-col section-gap-default">
  <% if release.pre_release_failed? %>
    <%= render AlertComponent.new(type: :error, title: raw(release.pre_release_error_message), full_screen: false) %>
  <% end %>

  <% if conflicting_branch_releases.present? %>
    <%= render AlertComponent.new(kind: :announcement, type: :announce, title: "Release branches are shared", full_screen: false) do %>
      This release branch is shared with other active release(s): <%= conflicting_branch_release_links %>
    <% end %>
  <% end %>

  <% unless version_bump_prs.empty? %>
    <%= render CardComponent.new(title: "Version Bumps",
                                 fold: false,
                                 size: :base,
                                 separator: true,
                                 emptiness: version_bump_prs.empty?) do |card| %>
      <% card.with_empty_state(text: "No version bump PRs are currently active.", banner_image: "check.svg") %>

      <%= render partial: "shared/divide_collection",
                 locals: {collection: render(PullRequestComponent.with_collection(version_bump_prs))} %>
    <% end %>
  <% end %>

  <% if changelog_present? %>
    <%= render CardComponent.new(title: "Changes since last release (#{commits_since_last.size})", separator: true, size: :base) do |card| %>
      <% card.with_action do %>
        <span class="text-xs text-secondary-50 items-center flex gap-1">
          Diff from <%= render BadgeComponent.new(text: changelog_from, kind: :badge) %>
        </span>
      <% end %>

      <%= render partial: "shared/divide_collection", locals: {collection: render(CommitComponent.with_collection(commits_since_last, backmerge_instructions: true))} %>
    <% end %>
  <% end %>

  <% if cherry_pick_mode? %>
    <%= render CardComponent.new(title: "Forward merges (#{forward_merges_count})",
                                 fold: false,
                                 size: :base,
                                 separator: true,
                                 emptiness: forward_merges_count.zero?) do |card| %>
      <% card.with_empty_state(text: "No commits from the working branch are queued for cherry-pick.",
                               banner_image: "git_commit_vertical.svg") %>

      <div class="divide-default">
        <% forward_merges&.each do |fmq| %>
          <%= render CommitComponent.new(commit: fmq.commit) do |c| %>
            <% c.with_actions do %>
              <% if fmq.pending? %>
                <%= render ButtonComponent.new(
                      scheme: :default,
                      options: cherry_pick_forward_merge_path(fmq),
                      type: :button,
                      size: :xxs,
                      disabled: !release.committable?,
                      label: "Cherry-pick",
                      html_options: {data: {turbo_confirm: "Cherry-pick this commit into the release branch?"}}
                    ) %>
              <% elsif fmq.in_progress? %>
                <%= status_badge("picking...", :ongoing, pulse: true) %>
              <% elsif fmq.success? %>
                <%= status_badge("picked", :success) %>
              <% elsif fmq.failed? %>
                <%= status_badge("failed to merge cleanly", :failure) %>
                <%= render ButtonComponent.new(
                      scheme: :default,
                      options: mark_as_picked_forward_merge_path(fmq),
                      type: :button,
                      size: :xxs,
                      label: "Mark as picked",
                      html_options: {data: {turbo_confirm: "Mark this commit as manually picked?"}}
                    ) %>
                <%= render ButtonComponent.new(
                      scheme: :default,
                      options: cherry_pick_forward_merge_path(fmq),
                      type: :button,
                      size: :xxs,
                      disabled: !release.committable?,
                      label: "Retry",
                      html_options: {data: {turbo_confirm: "Retry cherry-picking this commit?"}}
                    ) %>
              <% elsif fmq.manually_picked? %>
                <%= status_badge("manually picked", :neutral) %>
              <% end %>
            <% end %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>

  <%= render CardComponent.new(title: "Ongoing work (#{mid_release_stability_prs.count})",
                               fold: true,
                               size: :base,
                               separator: true,
                               emptiness: mid_release_stability_prs.empty?) do |card| %>
    <% card.with_empty_state(text: "There are no more pull requests targeting your release branch.",
                             banner_image: "check.svg") %>

    <%= render partial: "shared/divide_collection",
               locals: {collection: render(PullRequestComponent.with_collection(mid_release_stability_prs))} %>
  <% end %>

  <%= render CardComponent.new(title: "Change queue (#{change_queue_commits_count})",
                               fold: true,
                               size: :base,
                               separator: true,
                               subtitle: apply_help_text,
                               emptiness: change_queue_commits_count.zero?) do |card| %>
    <% card.with_action do %>
      <% if change_queue_commits.present? %>
        <%= render ButtonComponent.new(
              scheme: :default,
              options: apply_release_build_queue_path(release, build_queue),
              type: :button,
              size: :xxs,
              disabled: !release.committable?,
              label: "Apply now",
              html_options: {data: {turbo_confirm: "This will apply all the commits from the queue, are you sure?"}}
            ) do |b|
              b.with_icon("arrow_down_wide_narrow.svg", size: :sm)
            end %>
      <% end %>
    <% end %>

    <% card.with_empty_state(text: "The commit queue is empty.",
                             banner_image: "arrow_down_wide_narrow.svg") %>

    <%= render partial: "shared/divide_collection",
               locals: {collection: render(CommitComponent.with_collection(change_queue_commits, backmerge_instructions: true))} %>
  <% end %>

  <%= render CardComponent.new(title: "Latest applied commits (#{applied_commits.size})",
                               fold: true,
                               size: :base,
                               separator: true) do %>
    <% if applied_commits.present? %>
      <%= render partial: "shared/divide_collection",
                 locals: {collection: render(CommitComponent.with_collection(applied_commits, backmerge_instructions: true))} %>
    <% end %>
  <% end %>

  <%= render CardComponent.new(title: "Pending backmerges (#{open_backmerge_prs.size})",
                               fold: true,
                               separator: true,
                               size: :base,
                               emptiness: open_backmerge_prs.empty?) do |card| %>
    <% card.with_empty_state(text: "All backmerge pull requests have been merged.",
                             banner_image: "check.svg") %>

    <%= render partial: "shared/divide_collection",
               locals: {collection: render(PullRequestComponent.with_collection(open_backmerge_prs))} %>
  <% end %>
</div>
